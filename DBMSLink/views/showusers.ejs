<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Show Data</title>
    <style>
        table,th,tr,td {
            border: 2px solid black;
        }
        table {
            margin-top: 50px;
        }
        .search-container {
            margin-top: 50px;
            display: flex;
            justify-content: center;
        } 
        .new {
            display: flex;
            justify-content: end;
            border: 4px;
            border-radius: 5px;
        }

    </style>
</head>

<body>
     <div class="search-container">
        <form method="GET" action="/user/search">
            <input type="text" name="query" placeholder="Search by username or email" required>
            <button type="submit">Search</button>
        </form>
    </div>
    <form class="new" action="/user/new">
        <button>New</button>
    </form>
    <table>
        <tr>
            <th>Id</th>
            <th>Username</th>
            <th>Email</th>
        </tr>
        <% for(user of users) { %>
            <tr>
                <td>
                    <%= user.id %>
                </td>
                <td>
                    <%= user.username %>
                </td>
                <td>
                    <%= user.email %>
                </td>
                <td>
                    <form method="get" action="/user/<%=user.id%>/edit">
                        <button>Edit</button>
                    </form>
                </td>
                <td>
                    <form method="post" action="/user/<%=user.id%>?_method=DELETE">
                        <button type="submit">DELETE</button>
                    </form>
                </td>
                
            </tr>
            <%}%>
    </table>
</body>

</html>