<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>posts in detail</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <h2>Here is your post details</h2>
    <p>post id : <%= post.id %>
    </p>
    <div class="post">
        <h3 class="uesr">@<%= post.username %>
        </h3>
        <h4 class="cont">
            <%= post.content %>
        </h4>
        <form action="http://localhost:8080/posts/<%=post.id%>/edit">
            <button>Edit</button>
        </form>
    </div>
</body>

</html>