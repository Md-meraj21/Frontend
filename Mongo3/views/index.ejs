<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Whatsapp</title>
    <link rel="stylesheet" href="style.css">
</head>

<body>
    <h2>All Chats</h2>
    <form method="get" action="/chats/new">
        <button>New</button>
    </form>
    <% for(let chats of chat) { %>
        <div class="chats">
            <p>Sender :<%=chats.from%>
            </p>
            <p>Receiver :<%=chats.to%>
            </p>
            <div class="msg">
                <p>Message :<%=chats.msg%>
                </p>
                <form method="get" action="/chats/<%=chats._id%>/edit">
                    <button>Edit</button>
                </form>
                <hr>
                <form method="post" action="/chats/<%=chats._id%>?_method=DELETE">
                    <button>Delete</button>
                </form>
            </div>

            <hr>
            <p><%=chats.created_at.toString().split(" ")[4]%></p>
            <p><%=chats.created_at.toString().split(" ").slice(0,4).join(" ")%></p>
        </div>

        <br>
        
        <%}%>
</body>

</html>